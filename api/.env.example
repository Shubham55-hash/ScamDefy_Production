# ScamDefy Backend Environment Variables

# Google Gemini API Key - Used for AI-based scanning, linguistic analysis, and threat detection
GEMINI_API_KEY="your_gemini_api_key_here"

# Google Safe Browsing API Key - Used to verify if a URL is flagged as malicious by Google's threat database
GOOGLE_SAFE_BROWSING_API_KEY="your_google_safe_browsing_api_key_here"

# URLhaus API Key (Optional) - Used for checking deep malware/phishing URL datasets
URLHAUS_API_KEY="your_urlhaus_api_key_here"

# HuggingFace Cache Directory (Optional) - Used for the Voice Neural Net ML model caching
# HF_CACHE_DIR="/path/to/cache"

# ── Safety Circle (Guardian Alerts) ────────────────────────────────────────────
# SMTP configuration for sending privacy-preserving guardian notification emails.
# Any SMTP provider works (Gmail + App Password, SendGrid relay, Mailgun, etc.)
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your.address@gmail.com
#   SMTP_PASSWORD=xxxx xxxx xxxx xxxx   ← Use a Gmail App Password, NOT your main password
#   SMTP_FROM=your.address@gmail.com
#
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password_here"
SMTP_FROM="ScamDefy Sentinel <your_email@gmail.com>"
